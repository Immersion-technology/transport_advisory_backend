generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum SubscriptionTier {
  FOUNDING_FREE
  STANDARD
  FLEET
}

enum DocumentType {
  MOTOR_INSURANCE
  VEHICLE_LICENSE
  ROADWORTHINESS
  HACKNEY_PERMIT
  CHANGE_OF_OWNERSHIP
}

enum ApplicationStatus {
  PENDING
  PROCESSING
  SUBMITTED
  READY
  DELIVERED
  CANCELLED
}

enum ApplicationKind {
  RENEWAL
  FRESH
}

enum AdminPermission {
  MANAGE_APPLICATIONS
  MANAGE_USERS
  MANAGE_DELIVERIES
  MANAGE_REMINDERS
  MANAGE_ADMINS
}

enum DeliveryTier {
  STANDARD
  EXPRESS
  SAME_DAY
}

enum DeliveryStatus {
  PENDING
  DISPATCHED
  DELIVERED
}

enum ReminderChannel {
  EMAIL
  SMS
  WHATSAPP
}

enum MagicLinkPurpose {
  WELCOME
  LOGIN
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

model User {
  id                String            @id @default(uuid())
  email             String            @unique
  phone             String            @unique
  // Optional — users created via the auto-checkout flow start without a password
  // and authenticate via magic-link until they set one in settings.
  password          String?
  firstName         String
  lastName          String
  // Additional applicant fields collected on fresh-application step 3.
  // Optional so legacy users (created before this change) remain valid.
  othernames        String?
  gender            Gender?
  address           String?
  role              UserRole          @default(USER)
  permissions       AdminPermission[] @default([])
  isSuperAdmin      Boolean           @default(false)
  subscriptionTier  SubscriptionTier  @default(FOUNDING_FREE)
  subscriberNumber  Int?              @unique
  isActive          Boolean           @default(true)
  emailVerified     Boolean           @default(false)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  vehicles          Vehicle[]
  applications      Application[]
  verifications     VehicleVerification[]
  notifications     NotificationLog[]
  reminderPrefs     ReminderPreference[]
  magicLinks        MagicLinkToken[]

  @@map("users")
}

model Vehicle {
  id                  String   @id @default(uuid())
  userId              String
  plateNumber         String
  // Vehicle make/model/year/state are now optional. For renewal applications
  // the user supplies only the plate number on /start, and admin populates
  // these fields during the verification step. For fresh applications the
  // user fills them in on step 2 and they're saved immediately.
  make                String?
  model               String?
  year                Int?
  stateOfRegistration String?
  // Extended details — admin-populated on renewal verification, user-supplied
  // on fresh applications.
  colour              String?
  chassisNumber       String?
  engineNumber        String?
  registrationNumber  String?
  rwcNumber           String?
  // Photos uploaded by user (chassis #) or admin (license, etc.)
  chassisPhotoUrl     String?
  chassisPhotoPublicId String?
  licensePhotoUrl     String?
  licensePhotoPublicId String?
  // Pricing category — admin assigns during verification on renewal,
  // user picks during fresh application step 2.
  categoryId          String?
  // Verification gate. Renewals can't proceed to payment until admin sets
  // this to true (after populating make/model/category/RWC#/expirations).
  // Fresh applications create the vehicle as already-verified since the user
  // supplies all the data themselves.
  isVerified          Boolean  @default(false)
  verifiedAt          DateTime?
  verifiedById        String?
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user                User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  category            VehicleCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  documents           Document[]
  applications        Application[]

  @@unique([userId, plateNumber])
  @@index([categoryId])
  @@map("vehicles")
}

/**
 * Vehicle categorisation used for pricing. Seeded with Saloon / SUV / Pickup
 * / Bus (mini, mid, max) / Truck (10-tyre, 14-tyre, more) / Other; admin can
 * add more from the admin pricing page.
 */
model VehicleCategory {
  id          String   @id @default(uuid())
  key         String   @unique  // "saloon", "suv", "pickup", "bus_mini", ...
  label       String              // "Saloon Vehicles"
  description String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  pricing     DocumentPricing[]
  vehicles    Vehicle[]

  @@map("vehicle_categories")
}

/**
 * Per-(category, document) base price. Service fee is computed at checkout as
 * a percentage of the base — see SystemConfig key "service_fee_rate".
 * `notes` carries human-readable qualifiers ("6 months", "annual", etc.).
 */
model DocumentPricing {
  id           String       @id @default(uuid())
  categoryId   String
  documentType DocumentType
  basePrice    Float
  notes        String?
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  category     VehicleCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, documentType])
  @@index([documentType])
  @@map("document_pricing")
}

model Document {
  id              String       @id @default(uuid())
  vehicleId       String
  type            DocumentType
  expiryDate      DateTime
  isAutoPopulated Boolean      @default(false)
  fileUrl         String?
  filePublicId    String?
  notes           String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  vehicle         Vehicle      @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  reminderLogs    ReminderLog[]

  @@unique([vehicleId, type])
  @@map("documents")
}

model ReminderLog {
  id              String          @id @default(uuid())
  documentId      String
  triggerDays     Int
  channel         ReminderChannel
  sentAt          DateTime        @default(now())
  confirmedAt     DateTime?
  confirmToken    String?         @unique
  isConfirmed     Boolean         @default(false)

  document        Document        @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@map("reminder_logs")
}

model ReminderPreference {
  id          String          @id @default(uuid())
  userId      String
  channel     ReminderChannel
  isActive    Boolean         @default(true)
  triggerDays Int[]

  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, channel])
  @@map("reminder_preferences")
}

model Application {
  id              String            @id @default(uuid())
  userId          String
  vehicleId       String
  documentType    DocumentType
  kind            ApplicationKind   @default(RENEWAL)
  status          ApplicationStatus @default(PENDING)
  governmentFee   Float
  serviceFee      Float
  totalAmount     Float
  paystackRef     String?
  isPaid          Boolean           @default(false)
  paidAt          DateTime?
  notes           String?
  completedFileUrl String?
  completedFilePublicId String?
  completedAt     DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicle         Vehicle           @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  documents       ApplicationDocument[]
  delivery        Delivery?
  statusHistory   ApplicationStatusHistory[]

  @@map("applications")
}

model ApplicationDocument {
  id              String      @id @default(uuid())
  applicationId   String
  fileName        String
  fileUrl         String
  filePublicId    String
  fileType        String
  uploadedAt      DateTime    @default(now())

  application     Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("application_documents")
}

model ApplicationStatusHistory {
  id            String            @id @default(uuid())
  applicationId String
  status        ApplicationStatus
  notes         String?
  changedAt     DateTime          @default(now())
  changedBy     String?

  application   Application       @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("application_status_history")
}

model Delivery {
  id              String         @id @default(uuid())
  applicationId   String         @unique
  tier            DeliveryTier
  status          DeliveryStatus @default(PENDING)
  address         String
  city            String
  state           String
  recipientName   String
  recipientPhone  String
  fee             Float
  trackingCode    String?
  dispatchedAt    DateTime?
  deliveredAt     DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  application     Application    @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("deliveries")
}

model VehicleVerification {
  id              String   @id @default(uuid())
  userId          String?
  plateNumber     String
  reportData      Json
  fee             Float    @default(1000)
  paystackRef     String?
  isPaid          Boolean  @default(false)
  createdAt       DateTime @default(now())

  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("vehicle_verifications")
}

model NotificationLog {
  id        String          @id @default(uuid())
  userId    String
  channel   ReminderChannel
  subject   String
  message   String
  status    String
  sentAt    DateTime        @default(now())

  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_logs")
}

model PlateRegistry {
  id                  String    @id @default(uuid())
  plateNumber         String    @unique

  // Vehicle info
  make                String?
  model               String?
  year                Int?
  color               String?
  registeredState     String?
  ownerName           String?

  // Motor Insurance (as NIID would return)
  insurer             String?
  policyNumber        String?
  insuranceStartDate  DateTime?
  insuranceExpiryDate DateTime?
  insuranceCoverType  String?
  insuranceStatus     String?

  // Vehicle License (as AutoReg would return)
  licenseNumber       String?
  licenseIssueDate    DateTime?
  licenseExpiryDate   DateTime?
  licenseStatus       String?

  // Roadworthiness (as DVIS would return)
  rwCertNumber        String?
  rwInspectionDate    DateTime?
  rwExpiryDate        DateTime?
  rwStatus            String?

  // Hackney Permit (commercial)
  hackneyPermitNumber String?
  hackneyIssueDate    DateTime?
  hackneyExpiryDate   DateTime?
  hackneyOperator     String?
  hackneyStatus       String?

  notes               String?
  createdById         String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@map("plate_registry")
}

model MagicLinkToken {
  id          String           @id @default(uuid())
  userId      String
  token       String           @unique
  purpose     MagicLinkPurpose @default(LOGIN)
  expiresAt   DateTime
  consumedAt  DateTime?
  createdAt   DateTime         @default(now())

  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("magic_link_tokens")
}

model SystemConfig {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt

  @@map("system_config")
}
